Host *
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  #UseKeychain yes
  AddKeysToAgent yes
  ConnectTimeout=30
  SetEnv TERM=xterm-256color
  IdentityFile ~/.ssh/id_ed25519

Host 100.*
  User root
  LogLevel ERROR

Host 10.*
  User root
  LogLevel ERROR

# Settings for Arista EOS 4.14.7M
Host 10.0.1.2
  HostKeyAlgorithms ssh-rsa
  PubkeyAcceptedKeyTypes ssh-rsa

Host 192.168.0.*
  User root
  LogLevel ERROR

Host 192.168.23.*
  User root
  LogLevel ERROR
