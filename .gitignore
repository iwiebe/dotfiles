# Never commit private SSH keys or host records
.ssh/id_*
.ssh/*.pem
.ssh/known_hosts
.ssh/known_hosts.*
.ssh/authorized_keys

# macOS cruft
.DS_Store

# Stow backup dirs, if ever created here
.dotfiles_backup_*

# .claude: only track settings.json and statusline.sh.
# Everything else (history, sessions, projects, caches) is machine-local and
# may contain prompt/session content — never commit it.
.claude/*
!.claude/settings.json
!.claude/statusline.sh
!.claude/CLAUDE.md
